{"id":"737b9092-5655-40a7-bb3e-f8232259f05d","revision":0,"last_node_id":234,"last_link_id":344,"nodes":[{"id":203,"type":"ShowText|pysssss","pos":[1050,2150],"size":[530,540],"flags":{},"order":24,"mode":4,"inputs":[{"localized_name":"文本","name":"text","type":"STRING","link":325}],"outputs":[{"localized_name":"字符串","name":"STRING","shape":6,"type":"STRING","links":null}],"properties":{"cnr_id":"comfyui-custom-scripts","ver":"609f3afaa74b2f88ef9ce8d939626065e3247469","Node name for S&R":"ShowText|pysssss","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.8"}},"widgets_values":[]},{"id":59,"type":"ShowText|pysssss","pos":[360,1200],"size":[500,650],"flags":{},"order":20,"mode":0,"inputs":[{"localized_name":"文本","name":"text","type":"STRING","link":317}],"outputs":[{"label":"字符串","localized_name":"字符串","name":"STRING","shape":6,"type":"STRING","links":null}],"properties":{"cnr_id":"comfyui-custom-scripts","ver":"f2838ed5e59de4d73cde5c98354b87a8d3200190","Node name for S&R":"ShowText|pysssss","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.5.2"}},"widgets_values":["这是一段自然模式下的图像描述：\n画面呈现出一位身着洛丽塔风格服饰的少女，正坐在红褐色的软垫座椅上专注阅读。她拥有银白色的长发，头戴饰有花朵的宽檐帽，身穿带有黑色蝴蝶结的白色连衣裙，双手戴着黑色手套捧着一本厚重的红色书籍。\n构图采用中景视角，人物主体位于画面中央偏左位置，水平约在40%处，垂直居中。背景包含复古的书桌、台灯以及模糊的书架，营造出图书馆或书房的空间感。整体布局平衡，通过前景的人物与后景的陈设构建出清晰的纵深感。\n光线主要来自左侧窗户的自然光与书桌上的台灯暖光交织。自然光勾勒出人物轮廓，使银发和裙摆边缘产生柔和高光；台灯则照亮了书本和手部细节。整体色调偏暖，以米白、深红和木色为主，辅以柔和的阴影过渡。\n景深效果为中景深，人物面部和上半身清晰锐利，而背景的书架和窗户边缘呈现自然的虚化，突出了阅读的主题。细节质感上，衣物的蕾丝纹理、头发的丝缕光泽以及书本封面的皮革质感均清晰可见。氛围静谧优雅，展现了沉浸在书中的宁静时刻。"]},{"id":113,"type":"ShowText|pysssss","pos":[-1270,2110],"size":[390,520],"flags":{},"order":22,"mode":4,"inputs":[{"localized_name":"文本","name":"text","type":"STRING","link":322}],"outputs":[{"label":"字符串","localized_name":"字符串","name":"STRING","shape":6,"type":"STRING","links":null}],"properties":{"cnr_id":"comfyui-custom-scripts","ver":"f2838ed5e59de4d73cde5c98354b87a8d3200190","Node name for S&R":"ShowText|pysssss","